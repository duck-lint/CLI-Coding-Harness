{
  "$schema": "./ProjectContextPacket.schema.json",
  "metadata": {
    "id": "project_context_packet.json",
    "name": "Project Context Packet"
  },
  "project_spec": {
    "required": true,
    "authoritative": true,
    "document": "./project_spec.json",
    "schema_ref": "./ProjectSpec.schema.json"
  },
  "governance_primitives": {
    "required": true,
    "authoritative": true,
    "document": "./governance_primitives.json",
    "schema_ref": "./GovernancePrimitives.schema.json"
  },
  "known_failures": {
    "required": true,
    "authoritative": true,
    "document": "./known_failures.json",
    "schema_ref": "./KnownFailures.schema.json"
  },
  "open_decisions": {
    "required": true,
    "authoritative": true,
    "document": "./open_decisions.json",
    "schema_ref": "./OpenDecisions.schema.json"
  },
  "current_implementation": {
    "required": true,
    "authoritative": true,
    "document": [
      "../implementations/active/implementation_plan_**.json", 
      "../implementations/active/implementation_tracker_**.json"
    ],
    "schema_ref": [
      "../implementations/active/ImplementationPlan.schema.json",
      "../implementations/active/ImplementationTracker.schema.json"
    ]
  }
}