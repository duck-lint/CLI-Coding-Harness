{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "CurrentDecision": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "decision": {
          "title": "Decision",
          "type": "string"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "affected_surfaces": {
          "items": {
            "type": "string"
          },
          "title": "Affected Surfaces",
          "type": "array"
        },
        "status": {
          "default": "active",
          "enum": [
            "active",
            "superseded"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "id",
        "decision",
        "rationale",
        "affected_surfaces"
      ],
      "title": "CurrentDecision",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "open_decisions.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Open Decisions",
          "title": "Title",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "harness_target",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "source_format",
        "document_authority"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "Note": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "note": {
          "title": "Note",
          "type": "string"
        },
        "status": {
          "default": "active",
          "enum": [
            "active",
            "archived"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "id",
        "note"
      ],
      "title": "Note",
      "type": "object"
    },
    "PendingDecision": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "question": {
          "title": "Question",
          "type": "string"
        },
        "why_it_matters": {
          "title": "Why It Matters",
          "type": "string"
        },
        "options": {
          "items": {
            "type": "string"
          },
          "title": "Options",
          "type": "array"
        },
        "status": {
          "default": "active",
          "enum": [
            "active",
            "deferred",
            "blocked"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "id",
        "question",
        "why_it_matters",
        "options"
      ],
      "title": "PendingDecision",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "purpose": {
      "title": "Purpose",
      "type": "string"
    },
    "usage_rules": {
      "items": {
        "type": "string"
      },
      "title": "Usage Rules",
      "type": "array"
    },
    "current_decisions": {
      "items": {
        "$ref": "#/$defs/CurrentDecision"
      },
      "title": "Current Decisions",
      "type": "array"
    },
    "pending_decisions": {
      "items": {
        "$ref": "#/$defs/PendingDecision"
      },
      "title": "Pending Decisions",
      "type": "array"
    },
    "notes": {
      "items": {
        "$ref": "#/$defs/Note"
      },
      "title": "Notes",
      "type": "array"
    }
  },
  "required": [
    "metadata",
    "purpose",
    "usage_rules",
    "current_decisions",
    "pending_decisions",
    "notes"
  ],
  "title": "OpenDecisions",
  "type": "object"
}