{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "const": "project_context_packet.manifest.json",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "const": "Project Context Packet Manifest",
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "Source": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "enum": [
            "governance_primitives",
            "project_spec",
            "known_failures",
            "open_decisions",
            "active_implementation_plan",
            "active_implementation_tracker"
          ],
          "title": "Source Id",
          "type": "string"
        },
        "scope": {
          "enum": [
            "harness_global",
            "target_repo"
          ],
          "title": "Scope",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "required_when": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Required When"
        },
        "document_authority": {
          "enum": [
            "invariant_authority",
            "failure_evidence",
            "operational_state"
          ],
          "title": "Document Authority",
          "type": "string"
        },
        "document": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Document"
        },
        "document_glob": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Document Glob"
        },
        "schema_id": {
          "enum": [
            "governance_primitives",
            "project_spec",
            "known_failures",
            "open_decisions",
            "implementation_plan",
            "implementation_tracker"
          ],
          "title": "Schema Id",
          "type": "string"
        },
        "cardinality": {
          "enum": [
            "exactly_one",
            "zero_or_one",
            "zero_or_more",
            "one_or_more"
          ],
          "title": "Cardinality",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "scope",
        "required",
        "document_authority",
        "schema_id",
        "cardinality"
      ],
      "title": "Source",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/Source"
      },
      "title": "Sources",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "metadata",
    "sources"
  ],
  "title": "ProjectContextPacketManifest",
  "type": "object"
}