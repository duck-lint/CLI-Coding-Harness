{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Entry": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "pattern": {
          "title": "Pattern",
          "type": "string"
        },
        "trigger": {
          "title": "Trigger",
          "type": "string"
        },
        "symptom": {
          "title": "Symptom",
          "type": "string"
        },
        "likely_cause": {
          "title": "Likely Cause",
          "type": "string"
        },
        "prevention_rule": {
          "title": "Prevention Rule",
          "type": "string"
        },
        "easiest_check": {
          "title": "Easiest Check",
          "type": "string"
        },
        "last_seen": {
          "title": "Last Seen",
          "type": "string"
        },
        "status": {
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "id",
        "pattern",
        "trigger",
        "symptom",
        "likely_cause",
        "prevention_rule",
        "easiest_check",
        "last_seen",
        "status"
      ],
      "title": "Entry",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "known_failures.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Known Failures",
          "title": "Title",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "failure_evidence",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "source_format",
        "document_authority"
      ],
      "title": "Metadata",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "purpose": {
      "title": "Purpose",
      "type": "string"
    },
    "usage_rules": {
      "items": {
        "type": "string"
      },
      "title": "Usage Rules",
      "type": "array"
    },
    "entries_schema_ref": {
      "const": "./KnownFailureEntry.schema.json",
      "title": "Entries Schema Ref",
      "type": "string"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/Entry"
      },
      "title": "Entries",
      "type": "array"
    }
  },
  "required": [
    "metadata",
    "purpose",
    "usage_rules",
    "entries_schema_ref",
    "entries"
  ],
  "title": "KnownFailures",
  "type": "object"
}