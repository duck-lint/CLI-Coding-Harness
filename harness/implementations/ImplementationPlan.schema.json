{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "AcceptanceCriterion": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "criterion": {
          "title": "Criterion",
          "type": "string"
        },
        "required_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Required Evidence",
          "type": "array"
        }
      },
      "required": [
        "id",
        "criterion",
        "required_evidence"
      ],
      "title": "AcceptanceCriterion",
      "type": "object"
    },
    "ApprovalGate": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "boundary": {
          "title": "Boundary",
          "type": "string"
        },
        "requires": {
          "title": "Requires",
          "type": "string"
        }
      },
      "required": [
        "id",
        "boundary",
        "requires"
      ],
      "title": "ApprovalGate",
      "type": "object"
    },
    "AssumptionOrUnknown": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "statement": {
          "title": "Statement",
          "type": "string"
        },
        "risk_if_wrong": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Risk If Wrong"
        },
        "resolution_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Resolution Path"
        }
      },
      "required": [
        "id",
        "type",
        "statement",
        "risk_if_wrong",
        "resolution_path"
      ],
      "title": "AssumptionOrUnknown",
      "type": "object"
    },
    "CurrentRepoState": {
      "additionalProperties": false,
      "properties": {
        "surface": {
          "title": "Surface",
          "type": "string"
        },
        "state": {
          "title": "State",
          "type": "string"
        },
        "notes": {
          "title": "Notes",
          "type": "string"
        }
      },
      "required": [
        "surface",
        "state",
        "notes"
      ],
      "title": "CurrentRepoState",
      "type": "object"
    },
    "ImplementationIntent": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "why_it_matters": {
          "title": "Why It Matters",
          "type": "string"
        }
      },
      "required": [
        "id",
        "summary",
        "why_it_matters"
      ],
      "title": "ImplementationIntent",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "pattern": "^implementation_plan_\\d+\\.json$",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "pattern": "^Implementation \\d+ Plan$",
          "title": "Title",
          "type": "string"
        },
        "purpose": {
          "const": "This file outlines an implementation plan.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "operational_state",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "purpose",
        "source_format",
        "document_authority"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "Seam": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "status": {
          "default": "proposed",
          "enum": [
            "active",
            "proposed",
            "complete",
            "blocked"
          ],
          "title": "Status",
          "type": "string"
        },
        "evidence_target": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Target",
          "type": "array"
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "evidence_target"
      ],
      "title": "Seam",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "implementation_intent": {
      "items": {
        "$ref": "#/$defs/ImplementationIntent"
      },
      "title": "Implementation Intent",
      "type": "array"
    },
    "project_manager_report": {
      "title": "Project Manager Report",
      "type": "string"
    },
    "seams": {
      "items": {
        "$ref": "#/$defs/Seam"
      },
      "title": "Seams",
      "type": "array"
    },
    "non_goals": {
      "items": {
        "type": "string"
      },
      "title": "Non Goals",
      "type": "array"
    },
    "acceptance_criteria": {
      "items": {
        "$ref": "#/$defs/AcceptanceCriterion"
      },
      "title": "Acceptance Criteria",
      "type": "array"
    },
    "current_repo_runtime_state": {
      "items": {
        "$ref": "#/$defs/CurrentRepoState"
      },
      "title": "Current Repo Runtime State",
      "type": "array"
    },
    "assumptions_and_unknowns": {
      "items": {
        "$ref": "#/$defs/AssumptionOrUnknown"
      },
      "title": "Assumptions And Unknowns",
      "type": "array"
    },
    "affected_surfaces": {
      "items": {
        "type": "string"
      },
      "title": "Affected Surfaces",
      "type": "array"
    },
    "non_affected_surfaces": {
      "items": {
        "type": "string"
      },
      "title": "Non Affected Surfaces",
      "type": "array"
    },
    "completion_rules": {
      "items": {
        "type": "string"
      },
      "title": "Completion Rules",
      "type": "array"
    },
    "approval_gates": {
      "items": {
        "$ref": "#/$defs/ApprovalGate"
      },
      "title": "Approval Gates",
      "type": "array"
    },
    "closeout_notes": {
      "items": {
        "type": "string"
      },
      "title": "Closeout Notes",
      "type": "array"
    }
  },
  "required": [
    "metadata",
    "implementation_intent",
    "project_manager_report",
    "seams",
    "non_goals",
    "acceptance_criteria",
    "current_repo_runtime_state",
    "assumptions_and_unknowns",
    "affected_surfaces",
    "non_affected_surfaces",
    "completion_rules",
    "approval_gates",
    "closeout_notes"
  ],
  "title": "ImplementationPlan",
  "type": "object"
}