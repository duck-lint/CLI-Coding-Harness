{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "AgentInputPolicyEntry": {
      "additionalProperties": false,
      "properties": {
        "input_id": {
          "minLength": 1,
          "title": "Input Id",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "schema_ref": {
          "minLength": 1,
          "title": "Schema Ref",
          "type": "string"
        },
        "resolution": {
          "anyOf": [
            {
              "$ref": "#/$defs/AgentInputResolution"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "input_id",
        "required",
        "schema_ref"
      ],
      "title": "AgentInputPolicyEntry",
      "type": "object"
    },
    "AgentInputResolution": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "paths",
            "globs",
            "all_admissible"
          ],
          "title": "Mode",
          "type": "string"
        },
        "include_harness": {
          "default": false,
          "title": "Include Harness",
          "type": "boolean"
        },
        "paths": {
          "items": {
            "type": "string"
          },
          "title": "Paths",
          "type": "array"
        },
        "globs": {
          "items": {
            "type": "string"
          },
          "title": "Globs",
          "type": "array"
        },
        "max_file_bytes": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max File Bytes"
        },
        "max_total_bytes": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Total Bytes"
        }
      },
      "required": [
        "mode"
      ],
      "title": "AgentInputResolution",
      "type": "object"
    },
    "ArtifactTruthfulness": {
      "additionalProperties": false,
      "properties": {
        "compiled_runtime_artifacts": {
          "title": "Compiled Runtime Artifacts",
          "type": "string"
        },
        "output_policy_artifacts": {
          "title": "Output Policy Artifacts",
          "type": "string"
        },
        "raw_provider_artifacts": {
          "title": "Raw Provider Artifacts",
          "type": "string"
        },
        "non_runtime_templates": {
          "title": "Non Runtime Templates",
          "type": "string"
        }
      },
      "required": [
        "compiled_runtime_artifacts",
        "output_policy_artifacts",
        "raw_provider_artifacts",
        "non_runtime_templates"
      ],
      "title": "ArtifactTruthfulness",
      "type": "object"
    },
    "InstructionContract": {
      "additionalProperties": false,
      "properties": {
        "role": {
          "title": "Role",
          "type": "string"
        },
        "posture": {
          "title": "Posture",
          "type": "string"
        },
        "objective": {
          "title": "Objective",
          "type": "string"
        },
        "operating_context": {
          "items": {
            "type": "string"
          },
          "title": "Operating Context",
          "type": "array"
        },
        "project_manager_conduct": {
          "items": {
            "type": "string"
          },
          "title": "Project Manager Conduct",
          "type": "array"
        },
        "report_derivation_lenses": {
          "$ref": "#/$defs/ReportDerivationLenses"
        }
      },
      "required": [
        "role",
        "posture",
        "objective",
        "operating_context",
        "project_manager_conduct",
        "report_derivation_lenses"
      ],
      "title": "InstructionContract",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "const": "project_manager.agent.json",
          "title": "Id",
          "type": "string"
        },
        "agent_name": {
          "const": "Project Manager",
          "title": "Agent Name",
          "type": "string"
        },
        "document_authority": {
          "const": "global_harness",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "id",
        "agent_name",
        "document_authority"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "ProjectManagerOutputPolicyEntry": {
      "additionalProperties": false,
      "properties": {
        "output_id": {
          "const": "project_manager_report",
          "title": "Output Id",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "schema_ref": {
          "const": "../contracts/ProjectManagerReport.schema.json",
          "title": "Schema Ref",
          "type": "string"
        }
      },
      "required": [
        "output_id",
        "required",
        "schema_ref"
      ],
      "title": "ProjectManagerOutputPolicyEntry",
      "type": "object"
    },
    "ProofFrontier": {
      "additionalProperties": false,
      "properties": {
        "constraint_conflicts": {
          "title": "Constraint Conflicts",
          "type": "string"
        },
        "dominant_tension_justification": {
          "title": "Dominant Tension Justification",
          "type": "string"
        },
        "next_admissible_transformation": {
          "title": "Next Admissible Transformation",
          "type": "string"
        },
        "affected_surfaces": {
          "title": "Affected Surfaces",
          "type": "string"
        },
        "non_affected_surfaces": {
          "title": "Non Affected Surfaces",
          "type": "string"
        },
        "stop_conditions": {
          "title": "Stop Conditions",
          "type": "string"
        },
        "authority_constraints": {
          "title": "Authority Constraints",
          "type": "string"
        }
      },
      "required": [
        "constraint_conflicts",
        "dominant_tension_justification",
        "next_admissible_transformation",
        "affected_surfaces",
        "non_affected_surfaces",
        "stop_conditions",
        "authority_constraints"
      ],
      "title": "ProofFrontier",
      "type": "object"
    },
    "ReportDerivationLenses": {
      "additionalProperties": false,
      "properties": {
        "source_coverage": {
          "$ref": "#/$defs/SourceCoverage"
        },
        "trajectory_review": {
          "$ref": "#/$defs/TrajectoryReview"
        },
        "proof_frontier": {
          "$ref": "#/$defs/ProofFrontier"
        },
        "artifact_truthfulness": {
          "$ref": "#/$defs/ArtifactTruthfulness"
        },
        "status_semantics": {
          "$ref": "#/$defs/StatusSemantics"
        }
      },
      "required": [
        "source_coverage",
        "trajectory_review",
        "proof_frontier",
        "artifact_truthfulness",
        "status_semantics"
      ],
      "title": "ReportDerivationLenses",
      "type": "object"
    },
    "SourceCoverage": {
      "additionalProperties": false,
      "properties": {
        "basis": {
          "title": "Basis",
          "type": "string"
        },
        "truthfulness_check": {
          "title": "Truthfulness Check",
          "type": "string"
        }
      },
      "required": [
        "basis",
        "truthfulness_check"
      ],
      "title": "SourceCoverage",
      "type": "object"
    },
    "StatusSemantics": {
      "additionalProperties": false,
      "properties": {
        "admissible": {
          "title": "Admissible",
          "type": "string"
        },
        "admissibility_blocked": {
          "title": "Admissibility Blocked",
          "type": "string"
        },
        "rejected": {
          "title": "Rejected",
          "type": "string"
        },
        "needs_clarification": {
          "title": "Needs Clarification",
          "type": "string"
        }
      },
      "required": [
        "admissible",
        "admissibility_blocked",
        "rejected",
        "needs_clarification"
      ],
      "title": "StatusSemantics",
      "type": "object"
    },
    "TrajectoryReview": {
      "additionalProperties": false,
      "properties": {
        "current_posture": {
          "title": "Current Posture",
          "type": "string"
        },
        "thesis_attractor": {
          "title": "Thesis Attractor",
          "type": "string"
        },
        "drift_detection": {
          "title": "Drift Detection",
          "type": "string"
        },
        "structural_tension": {
          "title": "Structural Tension",
          "type": "string"
        }
      },
      "required": [
        "current_posture",
        "thesis_attractor",
        "drift_detection",
        "structural_tension"
      ],
      "title": "TrajectoryReview",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "provider": {
      "enum": [
        "openai",
        "anthropic"
      ],
      "title": "Provider",
      "type": "string"
    },
    "model": {
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "instruction_contract": {
      "$ref": "#/$defs/InstructionContract"
    },
    "agent_input_policy": {
      "items": {
        "$ref": "#/$defs/AgentInputPolicyEntry"
      },
      "title": "Agent Input Policy",
      "type": "array"
    },
    "agent_output_policy": {
      "items": {
        "$ref": "#/$defs/ProjectManagerOutputPolicyEntry"
      },
      "title": "Agent Output Policy",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "metadata",
    "provider",
    "model",
    "instruction_contract",
    "agent_input_policy",
    "agent_output_policy"
  ],
  "title": "ProjectManagerAgent",
  "type": "object"
}