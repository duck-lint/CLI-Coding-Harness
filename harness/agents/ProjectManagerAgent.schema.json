{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Input": {
      "additionalProperties": false,
      "properties": {
        "project_context_packet": {
          "$ref": "#/$defs/ProjectContextPacket"
        },
        "task": {
          "$ref": "#/$defs/Task"
        }
      },
      "required": [
        "project_context_packet",
        "task"
      ],
      "title": "Input",
      "type": "object"
    },
    "Instructions": {
      "additionalProperties": false,
      "properties": {
        "role": {
          "title": "Role",
          "type": "string"
        },
        "posture": {
          "title": "Posture",
          "type": "string"
        },
        "objective": {
          "title": "Objective",
          "type": "string"
        },
        "validity_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Validity Conditions",
          "type": "array"
        },
        "report_derivation_rules": {
          "$ref": "#/$defs/ReportDerivationRules"
        },
        "conduct_rules": {
          "items": {
            "type": "string"
          },
          "title": "Conduct Rules",
          "type": "array"
        },
        "review_lenses": {
          "$ref": "#/$defs/ReviewLenses"
        }
      },
      "required": [
        "role",
        "posture",
        "objective",
        "validity_conditions",
        "report_derivation_rules",
        "conduct_rules",
        "review_lenses"
      ],
      "title": "Instructions",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "agent_name": {
          "title": "Agent Name",
          "type": "string"
        },
        "mode": {
          "title": "Mode",
          "type": "string"
        }
      },
      "required": [
        "id",
        "agent_name",
        "mode"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "Output": {
      "additionalProperties": false,
      "properties": {
        "project_manager_report": {
          "$ref": "#/$defs/ProjectManagerReport"
        }
      },
      "required": [
        "project_manager_report"
      ],
      "title": "Output",
      "type": "object"
    },
    "ProjectContextPacket": {
      "additionalProperties": false,
      "properties": {
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "authoritative": {
          "title": "Authoritative",
          "type": "boolean"
        },
        "schema_ref": {
          "const": "../project-spec/ProjectContextPacket.schema.json",
          "title": "Schema Ref",
          "type": "string"
        }
      },
      "required": [
        "required",
        "authoritative",
        "schema_ref"
      ],
      "title": "ProjectContextPacket",
      "type": "object"
    },
    "ProjectManagerReport": {
      "additionalProperties": false,
      "properties": {
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "schema_ref": {
          "const": "../contracts/ProjectManagerReport.schema.json",
          "title": "Schema Ref",
          "type": "string"
        }
      },
      "required": [
        "required",
        "schema_ref"
      ],
      "title": "ProjectManagerReport",
      "type": "object"
    },
    "ReportDerivationRules": {
      "additionalProperties": false,
      "properties": {
        "evaluation_basis": {
          "title": "Evaluation Basis",
          "type": "string"
        },
        "drift_checks": {
          "title": "Drift Checks",
          "type": "string"
        },
        "next_step_recommendations": {
          "title": "Next Step Recommendations",
          "type": "string"
        },
        "repository_state": {
          "title": "Repository State",
          "type": "string"
        }
      },
      "required": [
        "evaluation_basis",
        "drift_checks",
        "next_step_recommendations",
        "repository_state"
      ],
      "title": "ReportDerivationRules",
      "type": "object"
    },
    "ReviewLenses": {
      "additionalProperties": false,
      "properties": {
        "invariant_coverage": {
          "title": "Invariant Coverage",
          "type": "string"
        },
        "task_coverage": {
          "title": "Task Coverage",
          "type": "string"
        },
        "source_coverage_truthfulness": {
          "title": "Source Coverage Truthfulness",
          "type": "string"
        },
        "conflict_visibility": {
          "title": "Conflict Visibility",
          "type": "string"
        },
        "admissible_transformation_coverage": {
          "title": "Admissible Transformation Coverage",
          "type": "string"
        },
        "surface_truthfulness": {
          "title": "Surface Truthfulness",
          "type": "string"
        },
        "evidence_quality": {
          "title": "Evidence Quality",
          "type": "string"
        },
        "fixture_truthfulness": {
          "title": "Fixture Truthfulness",
          "type": "string"
        },
        "posture_concreteness": {
          "title": "Posture Concreteness",
          "type": "string"
        },
        "thesis_attractor_discipline": {
          "title": "Thesis Attractor Discipline",
          "type": "string"
        },
        "tension_selection": {
          "title": "Tension Selection",
          "type": "string"
        },
        "frontier_selection": {
          "title": "Frontier Selection",
          "type": "string"
        },
        "optionality_preservation": {
          "title": "Optionality Preservation",
          "type": "string"
        }
      },
      "required": [
        "invariant_coverage",
        "task_coverage",
        "source_coverage_truthfulness",
        "conflict_visibility",
        "admissible_transformation_coverage",
        "surface_truthfulness",
        "evidence_quality",
        "fixture_truthfulness",
        "posture_concreteness",
        "thesis_attractor_discipline",
        "tension_selection",
        "frontier_selection",
        "optionality_preservation"
      ],
      "title": "ReviewLenses",
      "type": "object"
    },
    "Task": {
      "additionalProperties": false,
      "properties": {
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "authoritative": {
          "title": "Authoritative",
          "type": "boolean"
        },
        "schema_ref": {
          "const": "../runtime/Task.schema.json",
          "title": "Schema Ref",
          "type": "string"
        }
      },
      "required": [
        "required",
        "authoritative",
        "schema_ref"
      ],
      "title": "Task",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "instructions": {
      "$ref": "#/$defs/Instructions"
    },
    "input": {
      "$ref": "#/$defs/Input"
    },
    "output": {
      "$ref": "#/$defs/Output"
    }
  },
  "required": [
    "$schema",
    "metadata",
    "instructions",
    "input",
    "output"
  ],
  "title": "ProjectManagerAgent",
  "type": "object"
}