{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "AgentInputPolicyEntry": {
      "additionalProperties": false,
      "properties": {
        "input_id": {
          "const": "static_context_packet",
          "title": "Input Id",
          "type": "string"
        },
        "required": {
          "const": true,
          "title": "Required",
          "type": "boolean"
        },
        "schema_ref": {
          "const": "../project_spec/StaticContextPacketManifest.schema.json",
          "title": "Schema Ref",
          "type": "string"
        }
      },
      "required": [
        "input_id",
        "required",
        "schema_ref"
      ],
      "title": "AgentInputPolicyEntry",
      "type": "object"
    },
    "AgentOutputPolicyEntry": {
      "additionalProperties": false,
      "properties": {
        "input_id": {
          "const": "project_manager_report",
          "title": "Input Id",
          "type": "string"
        },
        "required": {
          "const": true,
          "title": "Required",
          "type": "boolean"
        },
        "schema_ref": {
          "const": "../contracts/ProjectManagerReport.schema.json",
          "title": "Schema Ref",
          "type": "string"
        }
      },
      "required": [
        "input_id",
        "required",
        "schema_ref"
      ],
      "title": "AgentOutputPolicyEntry",
      "type": "object"
    },
    "InstructionContract": {
      "additionalProperties": false,
      "properties": {
        "role": {
          "title": "Role",
          "type": "string"
        },
        "posture": {
          "title": "Posture",
          "type": "string"
        },
        "objective": {
          "title": "Objective",
          "type": "string"
        },
        "validity_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Validity Conditions",
          "type": "array"
        },
        "project_manager_report_derivation_rules": {
          "$ref": "#/$defs/ProjectManagerReportDerivationRules"
        },
        "conduct_rules": {
          "items": {
            "type": "string"
          },
          "title": "Conduct Rules",
          "type": "array"
        },
        "review_lenses": {
          "$ref": "#/$defs/ReviewLenses"
        }
      },
      "required": [
        "role",
        "posture",
        "objective",
        "validity_conditions",
        "project_manager_report_derivation_rules",
        "conduct_rules",
        "review_lenses"
      ],
      "title": "InstructionContract",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "const": "project_manager.agent.json",
          "title": "Id",
          "type": "string"
        },
        "agent_name": {
          "const": "Project Manager",
          "title": "Agent Name",
          "type": "string"
        }
      },
      "required": [
        "id",
        "agent_name"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "ProjectManagerReportDerivationRules": {
      "additionalProperties": false,
      "properties": {
        "evaluation_basis": {
          "title": "Evaluation Basis",
          "type": "string"
        },
        "drift_checks": {
          "title": "Drift Checks",
          "type": "string"
        },
        "next_step_recommendations": {
          "title": "Next Step Recommendations",
          "type": "string"
        },
        "repository_state": {
          "title": "Repository State",
          "type": "string"
        },
        "status_semantics": {
          "$ref": "#/$defs/StatusSemantics"
        }
      },
      "required": [
        "evaluation_basis",
        "drift_checks",
        "next_step_recommendations",
        "repository_state",
        "status_semantics"
      ],
      "title": "ProjectManagerReportDerivationRules",
      "type": "object"
    },
    "ReviewLenses": {
      "additionalProperties": false,
      "properties": {
        "invariant_coverage": {
          "title": "Invariant Coverage",
          "type": "string"
        },
        "task_coverage": {
          "title": "Task Coverage",
          "type": "string"
        },
        "source_coverage_truthfulness": {
          "title": "Source Coverage Truthfulness",
          "type": "string"
        },
        "conflict_visibility": {
          "title": "Conflict Visibility",
          "type": "string"
        },
        "admissible_transformation_coverage": {
          "title": "Admissible Transformation Coverage",
          "type": "string"
        },
        "surface_truthfulness": {
          "title": "Surface Truthfulness",
          "type": "string"
        },
        "evidence_quality": {
          "title": "Evidence Quality",
          "type": "string"
        },
        "fixture_truthfulness": {
          "title": "Fixture Truthfulness",
          "type": "string"
        },
        "posture_concreteness": {
          "title": "Posture Concreteness",
          "type": "string"
        },
        "thesis_attractor_discipline": {
          "title": "Thesis Attractor Discipline",
          "type": "string"
        },
        "tension_selection": {
          "title": "Tension Selection",
          "type": "string"
        },
        "frontier_selection": {
          "title": "Frontier Selection",
          "type": "string"
        },
        "optionality_preservation": {
          "title": "Optionality Preservation",
          "type": "string"
        }
      },
      "required": [
        "invariant_coverage",
        "task_coverage",
        "source_coverage_truthfulness",
        "conflict_visibility",
        "admissible_transformation_coverage",
        "surface_truthfulness",
        "evidence_quality",
        "fixture_truthfulness",
        "posture_concreteness",
        "thesis_attractor_discipline",
        "tension_selection",
        "frontier_selection",
        "optionality_preservation"
      ],
      "title": "ReviewLenses",
      "type": "object"
    },
    "StatusSemantics": {
      "additionalProperties": false,
      "properties": {
        "admissible": {
          "const": "The task can proceed under current project and task authority.",
          "title": "Admissible",
          "type": "string"
        },
        "admissibility_blocked": {
          "const": "The PM cannot judge or proceed because required basis, context, or authority is missing.",
          "title": "Admissibility Blocked",
          "type": "string"
        },
        "rejected": {
          "const": "The task conflicts with invariant project or harness authority.",
          "title": "Rejected",
          "type": "string"
        },
        "needs_clarification": {
          "const": "The task is ambiguous enough that user clarification is required, but no invariant conflict is established.",
          "title": "Needs Clarification",
          "type": "string"
        }
      },
      "required": [
        "admissible",
        "admissibility_blocked",
        "rejected",
        "needs_clarification"
      ],
      "title": "StatusSemantics",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "model": {
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "instruction_contract": {
      "$ref": "#/$defs/InstructionContract"
    },
    "agent_input_policy": {
      "items": {
        "$ref": "#/$defs/AgentInputPolicyEntry"
      },
      "title": "Agent Input Policy",
      "type": "array"
    },
    "agent_output_policy": {
      "items": {
        "$ref": "#/$defs/AgentOutputPolicyEntry"
      },
      "title": "Agent Output Policy",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "metadata",
    "model",
    "instruction_contract",
    "agent_input_policy",
    "agent_output_policy"
  ],
  "title": "ProjectManagerAgent",
  "type": "object"
}