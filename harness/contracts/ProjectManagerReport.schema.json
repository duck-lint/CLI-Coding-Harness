{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "DriftDetection": {
      "additionalProperties": false,
      "properties": {
        "drift_detected": {
          "title": "Drift Detected",
          "type": "boolean"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "drift_detected"
      ],
      "title": "DriftDetection",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "project_manager_report.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Project Manager Report",
          "title": "Title",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "generated_artifact",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "source_format",
        "document_authority"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "ProofFrontier": {
      "additionalProperties": false,
      "properties": {
        "constraint_conflicts": {
          "items": {
            "type": "string"
          },
          "title": "Constraint Conflicts",
          "type": "array"
        },
        "dominant_tension_justification": {
          "title": "Dominant Tension Justification",
          "type": "string"
        },
        "blocked": {
          "title": "Blocked",
          "type": "boolean"
        },
        "blocking_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Blocking Reason"
        },
        "next_admissible_transformation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Next Admissible Transformation"
        },
        "affected_surfaces": {
          "items": {
            "type": "string"
          },
          "title": "Affected Surfaces",
          "type": "array"
        },
        "non_affected_surfaces": {
          "items": {
            "type": "string"
          },
          "title": "Non Affected Surfaces",
          "type": "array"
        },
        "stop_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Stop Conditions",
          "type": "array"
        }
      },
      "required": [
        "constraint_conflicts",
        "dominant_tension_justification",
        "blocked",
        "affected_surfaces",
        "non_affected_surfaces",
        "stop_conditions"
      ],
      "title": "ProofFrontier",
      "type": "object"
    },
    "ReportSourceCoverageItem": {
      "additionalProperties": false,
      "properties": {
        "runtime_input_doc": {
          "title": "Runtime Input Doc",
          "type": "string"
        },
        "consumed": {
          "title": "Consumed",
          "type": "boolean"
        },
        "basis": {
          "items": {
            "type": "string"
          },
          "title": "Basis",
          "type": "array"
        }
      },
      "required": [
        "runtime_input_doc",
        "consumed",
        "basis"
      ],
      "title": "ReportSourceCoverageItem",
      "type": "object"
    },
    "TrajectoryReview": {
      "additionalProperties": false,
      "properties": {
        "current_posture": {
          "title": "Current Posture",
          "type": "string"
        },
        "thesis_attractor": {
          "title": "Thesis Attractor",
          "type": "string"
        },
        "drift_detection": {
          "$ref": "#/$defs/DriftDetection"
        },
        "invariant_constraints": {
          "items": {
            "type": "string"
          },
          "title": "Invariant Constraints",
          "type": "array"
        },
        "task_constraints": {
          "items": {
            "type": "string"
          },
          "title": "Task Constraints",
          "type": "array"
        },
        "structural_tension": {
          "title": "Structural Tension",
          "type": "string"
        }
      },
      "required": [
        "current_posture",
        "thesis_attractor",
        "drift_detection",
        "invariant_constraints",
        "task_constraints",
        "structural_tension"
      ],
      "title": "TrajectoryReview",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "report_status": {
      "enum": [
        "admissible",
        "admissibility_blocked",
        "rejected",
        "needs_clarification"
      ],
      "title": "Report Status",
      "type": "string"
    },
    "report_summary": {
      "title": "Report Summary",
      "type": "string"
    },
    "report_source_coverage": {
      "items": {
        "$ref": "#/$defs/ReportSourceCoverageItem"
      },
      "minItems": 1,
      "title": "Report Source Coverage",
      "type": "array"
    },
    "trajectory_review": {
      "$ref": "#/$defs/TrajectoryReview"
    },
    "proof_frontier": {
      "$ref": "#/$defs/ProofFrontier"
    }
  },
  "required": [
    "metadata",
    "report_status",
    "report_summary",
    "report_source_coverage",
    "trajectory_review",
    "proof_frontier"
  ],
  "title": "ProjectManagerReport",
  "type": "object"
}