{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "TaskMetadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "task.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Task",
          "title": "Title",
          "type": "string"
        },
        "purpose": {
          "const": "Records the current user task for a harness run.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "task_authority",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "purpose",
        "source_format",
        "document_authority"
      ],
      "title": "TaskMetadata",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/TaskMetadata"
    },
    "task_text": {
      "minLength": 1,
      "title": "Task Text",
      "type": "string"
    },
    "source": {
      "const": "cli",
      "title": "Source",
      "type": "string"
    }
  },
  "required": [
    "metadata",
    "task_text",
    "source"
  ],
  "title": "Task",
  "type": "object"
}