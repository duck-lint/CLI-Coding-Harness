{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "task.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Task",
          "title": "Title",
          "type": "string"
        },
        "purpose": {
          "const": "This file assigns the task to the agent.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "task_authority",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "purpose",
        "source_format",
        "document_authority"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "TaskItem": {
      "additionalProperties": false,
      "properties": {
        "task_text": {
          "title": "Task Text",
          "type": "string"
        },
        "created_at": {
          "title": "Created At",
          "type": "string"
        },
        "requested_agent": {
          "title": "Requested Agent",
          "type": "string"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        }
      },
      "required": [
        "task_text",
        "created_at",
        "requested_agent",
        "run_id"
      ],
      "title": "TaskItem",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "task": {
      "$ref": "#/$defs/TaskItem"
    }
  },
  "required": [
    "$schema",
    "metadata",
    "task"
  ],
  "title": "Task",
  "type": "object"
}