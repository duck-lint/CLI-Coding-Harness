    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "governance_primitives.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Governance Primitives",
          "title": "Title",
          "type": "string"
        },
        "context": {
          "const": "Global governance for the CLI harness. These primitives govern agent operation, execution boundaries, runtime artifact semantics, and authority separation when the harness is invoked against any target project repository, including the harness repository itself.",
