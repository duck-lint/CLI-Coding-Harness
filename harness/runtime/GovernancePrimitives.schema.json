{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "DocumentAuthorityClasses": {
      "additionalProperties": false,
      "properties": {
        "binding_authority": {
          "items": {
            "enum": [
              "global_harness",
              "harness_target",
              "runtime_policy",
              "operational_state"
            ],
            "type": "string"
          },
          "title": "Binding Authority",
          "type": "array"
        },
        "derived_runtime_artifacts": {
          "items": {
            "enum": [
              "compiled_runtime_artifact",
              "output_policy_artifact",
              "raw_provider_artifact"
            ],
            "type": "string"
          },
          "title": "Derived Runtime Artifacts",
          "type": "array"
        }
      },
      "required": [
        "binding_authority",
        "derived_runtime_artifacts"
      ],
      "title": "DocumentAuthorityClasses",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "governance_primitives.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Governance Primitives",
          "title": "Title",
          "type": "string"
        },
        "context": {
          "const": "Global governance for the CLI harness. These primitives govern agent operation, execution boundaries, runtime artifact semantics, and authority separation in every target repository the harness is placed inside and invoked against.",
          "title": "Context",
          "type": "string"
        },
        "purpose": {
          "const": "Define and delineate global harness-level invariants from harness target repository boundaries that every project workflow must respect.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "global_harness",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "context",
        "purpose",
        "source_format",
        "document_authority"
      ],
      "title": "Metadata",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "document_authority_classes": {
      "$ref": "#/$defs/DocumentAuthorityClasses"
    },
    "agent_contracts": {
      "items": {
        "enum": [
          "project_manager",
          "planning_manager",
          "review_manager",
          "red_team_manager",
          "implementation_manager",
          "archive_manager",
          "worker_adapter"
        ],
        "type": "string"
      },
      "title": "Agent Contracts",
      "type": "array"
    },
    "approval_sensitive_surfaces": {
      "default": [],
      "items": {
        "enum": [
          "global_harness",
          "agent_contracts",
          "output_policies",
          "runtime_orchestration",
          "tool_and_worker_surface",
          "provider_or_api_behavior",
          "compatibility_commitments"
        ],
        "type": "string"
      },
      "title": "Approval Sensitive Surfaces",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "metadata",
    "document_authority_classes",
    "agent_contracts"
  ],
  "title": "GovernancePrimitives",
  "type": "object"
}