{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "runtime_doctrine.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Runtime Doctrine",
          "title": "Title",
          "type": "string"
        },
        "purpose": {
          "const": "This file governs runtime orchestration.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "invariant_authority",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "purpose",
        "source_format",
        "document_authority"
      ],
      "title": "Metadata",
      "type": "object"
    },
    "ProjectManagerReport": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "title": "Description",
          "type": "string"
        },
        "invariant_properties": {
          "items": {
            "type": "string"
          },
          "title": "Invariant Properties",
          "type": "array"
        },
        "conflict_handling": {
          "title": "Conflict Handling",
          "type": "string"
        }
      },
      "required": [
        "description",
        "invariant_properties",
        "conflict_handling"
      ],
      "title": "ProjectManagerReport",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "runtime_job": {
      "items": {
        "type": "string"
      },
      "title": "Runtime Job",
      "type": "array"
    },
    "canonical_memory_rules": {
      "items": {
        "type": "string"
      },
      "title": "Canonical Memory Rules",
      "type": "array"
    },
    "authority_lenses": {
      "items": {
        "type": "string"
      },
      "title": "Authority Lenses",
      "type": "array"
    },
    "project_manager_report": {
      "$ref": "#/$defs/ProjectManagerReport"
    },
    "behavior_discipline": {
      "items": {
        "type": "string"
      },
      "title": "Behavior Discipline",
      "type": "array"
    },
    "done_criteria": {
      "items": {
        "type": "string"
      },
      "title": "Done Criteria",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "metadata",
    "runtime_job",
    "canonical_memory_rules",
    "authority_lenses",
    "project_manager_report",
    "behavior_discipline",
    "done_criteria"
  ],
  "title": "RuntimeDoctrine",
  "type": "object"
}