{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "AgentContextInputCoverageEntry": {
      "additionalProperties": false,
      "properties": {
        "input_id": {
          "title": "Input Id",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "status": {
          "enum": [
            "included",
            "missing",
            "invalid"
          ],
          "title": "Status",
          "type": "string"
        },
        "schema_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Ref"
        },
        "basis": {
          "items": {
            "type": "string"
          },
          "title": "Basis",
          "type": "array"
        }
      },
      "required": [
        "input_id",
        "required",
        "status"
      ],
      "title": "AgentContextInputCoverageEntry",
      "type": "object"
    },
    "AgentContextPacket": {
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "$ref": "#/$defs/AgentContextPacketMetadata"
        },
        "agent_contract": {
          "$ref": "#/$defs/AgentContract"
        },
        "resolved_inputs": {
          "$ref": "#/$defs/AgentResolvedInputs"
        },
        "input_coverage": {
          "items": {
            "$ref": "#/$defs/AgentContextInputCoverageEntry"
          },
          "title": "Input Coverage",
          "type": "array"
        }
      },
      "required": [
        "metadata",
        "agent_contract",
        "resolved_inputs"
      ],
      "title": "AgentContextPacket",
      "type": "object"
    },
    "AgentContextPacketMetadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "agent_context_packet.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Agent Context Packet",
          "title": "Title",
          "type": "string"
        },
        "purpose": {
          "const": "Agent-specific context compiled from the selected agent input policy.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "generated_artifact",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "purpose",
        "source_format",
        "document_authority"
      ],
      "title": "AgentContextPacketMetadata",
      "type": "object"
    },
    "AgentContract": {
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "minLength": 1,
          "title": "$Schema",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/AgentMetadata"
        },
        "provider": {
          "enum": [
            "openai",
            "anthropic"
          ],
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "instruction_contract": {
          "additionalProperties": true,
          "title": "Instruction Contract",
          "type": "object"
        },
        "agent_input_policy": {
          "items": {
            "$ref": "#/$defs/AgentInputPolicyEntry"
          },
          "title": "Agent Input Policy",
          "type": "array"
        },
        "agent_output_policy": {
          "items": {
            "$ref": "#/$defs/AgentOutputPolicyEntry"
          },
          "title": "Agent Output Policy",
          "type": "array"
        }
      },
      "required": [
        "$schema",
        "metadata",
        "provider",
        "model",
        "instruction_contract",
        "agent_input_policy",
        "agent_output_policy"
      ],
      "title": "AgentContract",
      "type": "object"
    },
    "AgentInputPolicyEntry": {
      "additionalProperties": false,
      "properties": {
        "input_id": {
          "minLength": 1,
          "title": "Input Id",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "schema_ref": {
          "minLength": 1,
          "title": "Schema Ref",
          "type": "string"
        },
        "resolution": {
          "anyOf": [
            {
              "$ref": "#/$defs/AgentInputResolution"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "input_id",
        "required",
        "schema_ref"
      ],
      "title": "AgentInputPolicyEntry",
      "type": "object"
    },
    "AgentInputResolution": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "paths",
            "globs",
            "all_admissible"
          ],
          "title": "Mode",
          "type": "string"
        },
        "include_harness": {
          "default": false,
          "title": "Include Harness",
          "type": "boolean"
        },
        "paths": {
          "items": {
            "type": "string"
          },
          "title": "Paths",
          "type": "array"
        },
        "globs": {
          "items": {
            "type": "string"
          },
          "title": "Globs",
          "type": "array"
        },
        "max_file_bytes": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max File Bytes"
        },
        "max_total_bytes": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Total Bytes"
        }
      },
      "required": [
        "mode"
      ],
      "title": "AgentInputResolution",
      "type": "object"
    },
    "AgentMetadata": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "agent_name": {
          "minLength": 1,
          "title": "Agent Name",
          "type": "string"
        }
      },
      "required": [
        "id",
        "agent_name"
      ],
      "title": "AgentMetadata",
      "type": "object"
    },
    "AgentOutputPolicyEntry": {
      "additionalProperties": false,
      "properties": {
        "output_id": {
          "minLength": 1,
          "title": "Output Id",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "schema_ref": {
          "minLength": 1,
          "title": "Schema Ref",
          "type": "string"
        }
      },
      "required": [
        "output_id",
        "required",
        "schema_ref"
      ],
      "title": "AgentOutputPolicyEntry",
      "type": "object"
    },
    "AgentResolvedInputs": {
      "additionalProperties": false,
      "properties": {
        "static_context_packet": {
          "anyOf": [
            {
              "$ref": "#/$defs/StaticContextPacket"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "repo_snapshot_packet": {
          "anyOf": [
            {
              "$ref": "#/$defs/RepoSnapshotPacket"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "AgentResolvedInputs",
      "type": "object"
    },
    "ApiCallPacketMetadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "api_call_packet.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "API Call Packet",
          "title": "Title",
          "type": "string"
        },
        "purpose": {
          "const": "Provider-neutral packet for one model call before provider-specific rendering.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "generated_artifact",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "purpose",
        "source_format",
        "document_authority"
      ],
      "title": "ApiCallPacketMetadata",
      "type": "object"
    },
    "GitContext": {
      "additionalProperties": false,
      "properties": {
        "available": {
          "title": "Available",
          "type": "boolean"
        },
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Commit"
        },
        "is_dirty": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Is Dirty"
        },
        "status_summary": {
          "items": {
            "type": "string"
          },
          "title": "Status Summary",
          "type": "array"
        },
        "failure": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failure"
        }
      },
      "required": [
        "available"
      ],
      "title": "GitContext",
      "type": "object"
    },
    "MissingSourceEntry": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "enum": [
            "governance_primitives",
            "project_spec",
            "known_failures",
            "open_decisions",
            "active_implementation_plan",
            "active_implementation_tracker"
          ],
          "title": "Source Id",
          "type": "string"
        },
        "schema_id": {
          "enum": [
            "governance_primitives",
            "project_spec",
            "known_failures",
            "open_decisions",
            "implementation_plan",
            "implementation_tracker"
          ],
          "title": "Schema Id",
          "type": "string"
        },
        "document_authority": {
          "enum": [
            "invariant_authority",
            "failure_evidence",
            "operational_state"
          ],
          "title": "Document Authority",
          "type": "string"
        },
        "effect": {
          "enum": [
            "blocks_compilation",
            "recorded_absent"
          ],
          "title": "Effect",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "schema_id",
        "document_authority",
        "effect"
      ],
      "title": "MissingSourceEntry",
      "type": "object"
    },
    "OmittedRepoSnapshotFile": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "reason": {
          "enum": [
            "gitignored",
            "harness_excluded",
            "excluded_path",
            "binary",
            "too_large",
            "not_found",
            "outside_repo",
            "read_error"
          ],
          "title": "Reason",
          "type": "string"
        },
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        }
      },
      "required": [
        "path",
        "reason"
      ],
      "title": "OmittedRepoSnapshotFile",
      "type": "object"
    },
    "RepoSnapshotFile": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "size_bytes": {
          "title": "Size Bytes",
          "type": "integer"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "encoding": {
          "const": "utf-8",
          "title": "Encoding",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "path",
        "size_bytes",
        "sha256",
        "encoding",
        "content"
      ],
      "title": "RepoSnapshotFile",
      "type": "object"
    },
    "RepoSnapshotPacket": {
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "$ref": "#/$defs/RepoSnapshotPacketMetadata"
        },
        "selection": {
          "$ref": "#/$defs/RepoSnapshotSelection"
        },
        "files": {
          "items": {
            "$ref": "#/$defs/RepoSnapshotFile"
          },
          "title": "Files",
          "type": "array"
        },
        "omitted_files": {
          "items": {
            "$ref": "#/$defs/OmittedRepoSnapshotFile"
          },
          "title": "Omitted Files",
          "type": "array"
        },
        "summary": {
          "$ref": "#/$defs/RepoSnapshotSummary"
        }
      },
      "required": [
        "metadata",
        "selection",
        "files",
        "summary"
      ],
      "title": "RepoSnapshotPacket",
      "type": "object"
    },
    "RepoSnapshotPacketMetadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "repo_snapshot_packet.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Repo Snapshot Packet",
          "title": "Title",
          "type": "string"
        },
        "purpose": {
          "const": "Compiled repo file evidence selected for a model call.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "generated_artifact",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "title",
        "purpose",
        "source_format",
        "document_authority"
      ],
      "title": "RepoSnapshotPacketMetadata",
      "type": "object"
    },
    "RepoSnapshotSelection": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "paths",
            "globs",
            "all_admissible"
          ],
          "title": "Mode",
          "type": "string"
        },
        "include_harness": {
          "default": false,
          "title": "Include Harness",
          "type": "boolean"
        },
        "repo_root": {
          "title": "Repo Root",
          "type": "string"
        },
        "requested_paths": {
          "items": {
            "type": "string"
          },
          "title": "Requested Paths",
          "type": "array"
        },
        "requested_globs": {
          "items": {
            "type": "string"
          },
          "title": "Requested Globs",
          "type": "array"
        },
        "exclusions": {
          "items": {
            "type": "string"
          },
          "title": "Exclusions",
          "type": "array"
        },
        "gitignore_respected": {
          "title": "Gitignore Respected",
          "type": "boolean"
        },
        "harness_excluded": {
          "title": "Harness Excluded",
          "type": "boolean"
        }
      },
      "required": [
        "mode",
        "repo_root",
        "gitignore_respected",
        "harness_excluded"
      ],
      "title": "RepoSnapshotSelection",
      "type": "object"
    },
    "RepoSnapshotSummary": {
      "additionalProperties": false,
      "properties": {
        "included_count": {
          "title": "Included Count",
          "type": "integer"
        },
        "omitted_count": {
          "title": "Omitted Count",
          "type": "integer"
        },
        "total_included_bytes": {
          "title": "Total Included Bytes",
          "type": "integer"
        }
      },
      "required": [
        "included_count",
        "omitted_count",
        "total_included_bytes"
      ],
      "title": "RepoSnapshotSummary",
      "type": "object"
    },
    "RuntimeBudgetDefaults": {
      "additionalProperties": false,
      "properties": {
        "max_input_tokens": {
          "exclusiveMinimum": 0,
          "title": "Max Input Tokens",
          "type": "integer"
        },
        "reserved_output_tokens": {
          "exclusiveMinimum": 0,
          "title": "Reserved Output Tokens",
          "type": "integer"
        },
        "oversize_strategy": {
          "const": "fail_or_batch",
          "title": "Oversize Strategy",
          "type": "string"
        },
        "truncation": {
          "const": "disabled",
          "title": "Truncation",
          "type": "string"
        }
      },
      "required": [
        "max_input_tokens",
        "reserved_output_tokens",
        "oversize_strategy",
        "truncation"
      ],
      "title": "RuntimeBudgetDefaults",
      "type": "object"
    },
    "RuntimeBudgetPolicy": {
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "$Schema"
        },
        "default": {
          "$ref": "#/$defs/RuntimeBudgetDefaults"
        }
      },
      "required": [
        "default"
      ],
      "title": "RuntimeBudgetPolicy",
      "type": "object"
    },
    "SourceCoverageEntry": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "enum": [
            "governance_primitives",
            "project_spec",
            "known_failures",
            "open_decisions",
            "active_implementation_plan",
            "active_implementation_tracker"
          ],
          "title": "Source Id",
          "type": "string"
        },
        "layer": {
          "const": "static_context",
          "title": "Layer",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "required_when": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Required When"
        },
        "schema_id": {
          "enum": [
            "governance_primitives",
            "project_spec",
            "known_failures",
            "open_decisions",
            "implementation_plan",
            "implementation_tracker"
          ],
          "title": "Schema Id",
          "type": "string"
        },
        "document_authority": {
          "enum": [
            "invariant_authority",
            "failure_evidence",
            "operational_state"
          ],
          "title": "Document Authority",
          "type": "string"
        },
        "status": {
          "enum": [
            "included",
            "missing",
            "invalid"
          ],
          "title": "Status",
          "type": "string"
        },
        "resolved_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Path"
        },
        "validation": {
          "$ref": "#/$defs/SourceValidation"
        },
        "basis": {
          "items": {
            "type": "string"
          },
          "title": "Basis",
          "type": "array"
        }
      },
      "required": [
        "source_id",
        "layer",
        "required",
        "schema_id",
        "document_authority",
        "status",
        "validation"
      ],
      "title": "SourceCoverageEntry",
      "type": "object"
    },
    "SourceValidation": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "passed",
            "failed",
            "not_run"
          ],
          "title": "Status",
          "type": "string"
        },
        "validator": {
          "const": "pydantic",
          "title": "Validator",
          "type": "string"
        },
        "model": {
          "enum": [
            "governance_primitives",
            "project_spec",
            "known_failures",
            "open_decisions",
            "implementation_plan",
            "implementation_tracker"
          ],
          "title": "Model",
          "type": "string"
        },
        "normalized_output_available": {
          "title": "Normalized Output Available",
          "type": "boolean"
        },
        "failure": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failure"
        }
      },
      "required": [
        "status",
        "validator",
        "model",
        "normalized_output_available"
      ],
      "title": "SourceValidation",
      "type": "object"
    },
    "StaticContextPacket": {
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "$ref": "#/$defs/StaticContextPacketMetadata"
        },
        "governance_primitives": {
          "additionalProperties": true,
          "title": "Governance Primitives",
          "type": "object"
        },
        "project_spec": {
          "additionalProperties": true,
          "title": "Project Spec",
          "type": "object"
        },
        "known_failures": {
          "additionalProperties": true,
          "title": "Known Failures",
          "type": "object"
        },
        "open_decisions": {
          "additionalProperties": true,
          "title": "Open Decisions",
          "type": "object"
        },
        "active_implementation_plan": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Active Implementation Plan"
        },
        "active_implementation_tracker": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Active Implementation Tracker"
        },
        "source_coverage": {
          "items": {
            "$ref": "#/$defs/SourceCoverageEntry"
          },
          "title": "Source Coverage",
          "type": "array"
        },
        "missing_sources": {
          "items": {
            "$ref": "#/$defs/MissingSourceEntry"
          },
          "title": "Missing Sources",
          "type": "array"
        }
      },
      "required": [
        "metadata",
        "governance_primitives",
        "project_spec",
        "known_failures",
        "open_decisions",
        "source_coverage"
      ],
      "title": "StaticContextPacket",
      "type": "object"
    },
    "StaticContextPacketMetadata": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "const": "static_context_packet.json",
          "title": "Document Id",
          "type": "string"
        },
        "title": {
          "const": "Static Context Packet",
          "title": "Title",
          "type": "string"
        },
        "purpose": {
          "const": "Compiled static authority and operational context from StaticContextPacketManifest.",
          "title": "Purpose",
          "type": "string"
        },
        "source_format": {
          "const": "json",
          "title": "Source Format",
          "type": "string"
        },
        "document_authority": {
          "const": "generated_artifact",
          "title": "Document Authority",
          "type": "string"
        }
      },
      "required": [
        "document_id",
