{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "RuntimeBudgetDefaults": {
      "additionalProperties": false,
      "properties": {
        "max_input_tokens": {
          "exclusiveMinimum": 0,
          "title": "Max Input Tokens",
          "type": "integer"
        },
        "reserved_output_tokens": {
          "exclusiveMinimum": 0,
          "title": "Reserved Output Tokens",
          "type": "integer"
        },
        "oversize_strategy": {
          "const": "fail_or_batch",
          "title": "Oversize Strategy",
          "type": "string"
        },
        "truncation": {
          "const": "disabled",
          "title": "Truncation",
          "type": "string"
        }
      },
      "required": [
        "max_input_tokens",
        "reserved_output_tokens",
        "oversize_strategy",
        "truncation"
      ],
      "title": "RuntimeBudgetDefaults",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "$Schema"
    },
    "default": {
      "$ref": "#/$defs/RuntimeBudgetDefaults"
    }
  },
  "required": [
    "default"
  ],
  "title": "RuntimeBudgetPolicy",
  "type": "object"
}