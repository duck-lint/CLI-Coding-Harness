{
  "default": {
    "max_model_calls_per_run": 3,
    "max_successive_agent_depth": 2,
    "max_retries_per_agent": 1,
    "max_input_tokens_per_call": 60000,
    "max_output_tokens_per_call": 4000,
    "max_context_packet_tokens": 60000,
    "reserved_output_tokens": 4000,
    "oversize_strategy": "fail_or_batch",
    "truncation": "disabled",
    "default_model": "gpt-5.4"
  },
  "tools": {
    "web_search_enabled": false,
    "container_enabled": false,
    "external_network_enabled": false,
    "shell_enabled_for_agents": false,
    "file_write_enabled_for_agents": false
  },
  "workers": {
    "codex_cli_enabled": false,
    "requires_apply_phase": true,
    "requires_human_approval": true
  }
}
